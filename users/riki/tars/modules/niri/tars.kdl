output "eDP-1" {
	mode "2880x1800@120.001"
	position x=1920 y=0
	focus-at-startup
	hot-corners {
		off
	}
}
switch-events {
	lid-close {
		spawn "fish" "-c" "on-lid-close"
	}
	lid-open {
		spawn "fish" "-c" "on-lid-open"
	}
}
environment {
	//GDK_SCALE "2"
	//QT_SCALE_FACTOR "2"
	//QT_AUTO_SCREEN_SCALE_FACTOR "1"
}